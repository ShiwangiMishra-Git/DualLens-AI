# Copy this file to config.json and fill in your credentials.
# Never commit config.json — it is listed in .gitignore.
#
# config.json format:
# {
#     "API_KEY": "your_openai_api_key_here",
#     "OPENAI_API_BASE": "https://your_openai_api_base/v1"
# }
#
# Alternatively, export these environment variables before running the notebook:
# export OPENAI_API_KEY=your_openai_api_key_here
# export OPENAI_BASE_URL=https://your_openai_api_base/v1
