# Secrets
config.json
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Jupyter
.ipynb_checkpoints/

# Generated cache (reproducible — regenerate by running the notebook)
cache/*
!cache/.gitkeep
# Seed cache files — pre-generated so fresh clones skip expensive LLM calls
!cache/pdf_summary.txt
!cache/ai_features.json
!cache/strategy_explanations.json
!cache/strategy_recommendations.json

# Generated outputs
outputs/*
!outputs/.gitkeep

# ChromaDB vector store (large, regenerable)
chroma_db/
*.sqlite3

# OS
.DS_Store
Thumbs.db
